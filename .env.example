# Environment variables for CC Security Proxy
# Copy this file to .env and fill in your values

# Proxy settings
PROXY_PORT=8080
PROXY_HOST=127.0.0.1

# Upstream relay station URL (the untrusted API中转站)
UPSTREAM_URL=https://your-relay.example.com

# Security mode: default | protected | smart
MODE=smart

# LLM settings (for smart mode)
# DeepSeek: LLM_BASE_URL=https://api.deepseek.com/v1 LLM_MODEL=deepseek-v4-flash
# OpenAI:  LLM_BASE_URL=https://api.openai.com/v1    LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=10

# Sandbox settings (for protected/smart modes)
SANDBOX_TIMEOUT=30
SANDBOX_IMAGE=cc-security-sandbox
DOCKER_HOST=unix:///var/run/docker.sock

# Logging
LOG_LEVEL=INFO
